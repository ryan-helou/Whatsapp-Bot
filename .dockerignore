# Never copy the host's node_modules into the image — it may contain
# platform-specific native binaries (sharp, etc.) built for macOS that would
# clobber the Linux deps `npm ci` installs. Let npm ci build the right ones.
node_modules

# Secrets and runtime state are provided at runtime (env_file + volumes),
# never baked into the image.
.env
auth
data
credentials

# Dev noise.
.git
*.log
npm-debug.log*
