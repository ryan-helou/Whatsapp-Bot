# Copy this file to ".env" and fill in your values.
# cp .env.example .env

# ---- Google Sheet (message/schedule source) ----
# Path to the Google service-account JSON key you download from Google Cloud.
GOOGLE_SERVICE_ACCOUNT_KEY_FILE=./credentials/service-account.json
# The Sheet ID from its URL: docs.google.com/spreadsheets/d/<THIS_PART>/edit
SHEET_ID=
# Tab name + range. Leave as-is if your tab is called "Schedule".
SHEET_RANGE=Schedule!A2:H

# ---- Scheduling ----
# Default timezone if a row leaves the Timezone column blank.
DEFAULT_TIMEZONE=America/New_York
# How often (seconds) to re-read the sheet so edits apply without a restart.
POLL_SHEET_SECONDS=300
# If the bot was offline at send time, still send within this many minutes.
CATCHUP_GRACE_MINUTES=120

# ---- Anti-ban timing (fine to leave default) ----
JITTER_MAX_SECONDS=90
SEND_GAP_MIN_SECONDS=15
SEND_GAP_MAX_SECONDS=60
MAX_RETRIES=2

# ---- Safety ----
# Set to true for the first run to preview sends without actually sending.
DRY_RUN=false

# ---- Telegram control bot (optional) ----
# Text the bot in plain English to edit your schedule ("swap Jacob for John in
# the cleanup message"). Leave TELEGRAM_BOT_TOKEN blank to disable the bot.
# Token from @BotFather on Telegram:
TELEGRAM_BOT_TOKEN=
# Your numeric Telegram user ID(s), comma-separated. Only these can control the
# bot. If blank, the bot replies with your ID the first time you message it.
TELEGRAM_ALLOWED_USER_IDS=
# Anthropic API key (powers the natural-language understanding). Get one at
# console.anthropic.com. Required only if the Telegram bot is enabled.
ANTHROPIC_API_KEY=
# Model (leave default unless you have a reason to change it):
ANTHROPIC_MODEL=claude-opus-4-8
# Optional: get a daily summary DM of what went out. "HH:MM" in DEFAULT_TIMEZONE.
# Leave blank to turn it off.
DAILY_SUMMARY_TIME=
